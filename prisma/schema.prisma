  confirmation_token
  reauthentication_token
  recovery_token
  email_change_token_new
  email_change_token_current
  phone_change_token

  @@schema("auth")
}

enum oauth_authorization_status {
  pending
  approved
  denied
  expired

  @@schema("auth")
}

enum oauth_client_type {
  public
  confidential

  @@schema("auth")
}

enum oauth_registration_type {
  dynamic
  manual

  @@schema("auth")
}

enum oauth_response_type {
  code

  @@schema("auth")
}

model bot_approval_tokens {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String   @db.Uuid
  action_summary String
  preview_data   Json?
  token          String   @unique
  status         String   @default("pending")
  expires_at     DateTime @db.Timestamptz(6)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  user           users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_bot_approval_tokens_user")
  @@index([token], map: "idx_bot_approval_tokens_token")
  @@schema("public")
}

model bot_usage_log {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?  @db.Uuid
  command    String
  metadata   Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  user       users?   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_bot_usage_log_user_id")
  @@index([created_at(sort: Desc)], map: "idx_bot_usage_log_created_at")
  @@schema("public")
}

model card_snapshots {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String   @db.Uuid
  reason         String
  snapshot_data  Json
  status         String   @default("pending")
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  rolled_back_at DateTime? @db.Timestamptz(6)
  user           users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_card_snapshots_user_id")
  @@index([status], map: "idx_card_snapshots_status")
  @@schema("public")
}
