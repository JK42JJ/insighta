generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["auth", "public"]
}

model UserVideoState {
  id                     String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String         @db.Uuid
  videoId                String         @map("video_id") @db.Uuid
  is_in_ideation         Boolean        @default(true)
  user_note              String?
  /// Tiptap JSON for the Notion-style side editor (Phase 1-4 MVP).
  /// Source of truth for rich notes. `user_note` is kept as a dual-written plain-text extract
  /// so that the existing eviction rule (`user_note IS NULL`) continues to work unchanged.
  user_note_json         Json?          @map("user_note_json") @db.JsonB
  watch_position_seconds Int?           @default(0)
  is_watched             Boolean?       @default(false)
  cell_index             Int?           @default(-1)
  level_id               String?        @default("scratchpad")
  mandala_id             String?        @db.Uuid
  sort_order             Int?
  /// True when the row was inserted by the auto-add pipeline (recommendation_cache → user_video_states).
  /// Selective replace of stale recs only deletes WHERE auto_added=true AND user_note IS NULL
  /// AND is_watched=false AND watch_position_seconds=0 AND is_in_ideation=false.
  /// User trace on an auto-added row promotes it to permanent (preserved across refreshes).
  auto_added             Boolean        @default(false)
  added_to_ideation_at   DateTime       @default(now()) @db.Timestamptz(6)
  /// CP457+ pin/bookmark: NULL = unpinned, timestamp = pinned moment.
  /// Used by `idx_user_video_states_pinned_at` partial index for filter view.
  pinned_at              DateTime?      @db.Timestamptz(6)
  /// CP466 Add Cards surfacing — moment this row was last surfaced as a
  /// recommendation candidate in an Add Cards panel session.
  /// NULL = never surfaced. Layer 1 Coverage prefers un-surfaced rows
  /// for diversity (도배 회피). Spec: docs/design/add-cards-2026-05-18.md.
  surfaced_at            DateTime?      @db.Timestamptz(6)
  /// CP498 PR3b — A-stage relevance: Haiku score (0-100) of this card vs its
  /// mandala centerGoal. USER-SCOPED (unique user_id+videoId) — no cross-user
  /// leak. NULL = not yet backfilled; filled by the relevance-backfill queue.
  relevance_pct          Int?
  relevance_at           DateTime?      @db.Timestamptz(6)
  /// CP504 §0.7 — raw rubric axes (cell_fit / goal_contribution / actionability)
  /// that compose into relevance_pct. Was log-only; persisted so axis-weight
  /// re-tuning (0.4/0.4/0.2) can be measured. No write-path/scoring change here.
  /// Raw SQL DDL: prisma/migrations/relevance-detail/001_relevance_detail.sql
  relevance_detail       Json?          @db.JsonB
  createdAt              DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  users                  users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  video                  youtube_videos @relation(fields: [videoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  mandala                user_mandalas? @relation(fields: [mandala_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([user_id, videoId])
  @@index([user_id], map: "idx_user_video_states_user_id")
  @@index([videoId], map: "idx_user_video_states_video_id")
  @@index([mandala_id], map: "idx_user_video_states_mandala_id")
  @@index([mandala_id, cell_index, auto_added], map: "idx_user_video_states_auto_add_lookup")
  @@index([user_id, pinned_at(sort: Desc)], map: "idx_user_video_states_pinned_at")
  @@index([user_id, mandala_id, surfaced_at(sort: Desc)], map: "idx_user_video_states_surfaced")
  @@map("user_video_states")
  @@schema("public")
}

