generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["auth", "public"]
}

model UserVideoState {
  id                     String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String         @db.Uuid
  videoId                String         @map("video_id") @db.Uuid
  is_in_ideation         Boolean        @default(true)
  user_note              String?
  watch_position_seconds Int?           @default(0)
  is_watched             Boolean?       @default(false)
  cell_index             Int?           @default(-1)
  level_id               String?        @default("scratchpad")
  mandala_id             String?        @db.Uuid
  sort_order             Int?
  added_to_ideation_at   DateTime       @default(now()) @db.Timestamptz(6)
  createdAt              DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  users                  users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  video                  youtube_videos @relation(fields: [videoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  mandala                user_mandalas? @relation(fields: [mandala_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([user_id, videoId])
  @@index([user_id], map: "idx_user_video_states_user_id")
  @@index([videoId], map: "idx_user_video_states_video_id")
  @@index([mandala_id], map: "idx_user_video_states_mandala_id")
  @@map("user_video_states")
  @@schema("public")
}

