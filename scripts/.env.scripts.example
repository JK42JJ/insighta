# =============================================================================
# Scripts Environment Configuration (Example)
# =============================================================================
# Copy this file to .env.scripts and fill in your values.
# =============================================================================

# Project paths
PROJECT_ROOT="/path/to/insighta"
CLAUDE_PROJECTS_DIR="$HOME/.claude/projects/-Users-yourname-cursor-insighta"
CLAUDE_TASK_GLOB="/private/tmp/claude-*/-Users-yourname-cursor-insighta/tasks"

# Domain & hosts
DOMAIN="insighta.one"
EC2_HOST="x.x.x.x"
EC2_USER="ubuntu"
SSH_HOST="ubuntu@x.x.x.x"

# GitHub
GITHUB_REPO="owner/repo"

# Supabase
SUPABASE_PROJECT_REF="your-project-ref"
