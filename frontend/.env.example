# =============================================================================
# TubeArchive Frontend - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# =============================================================================

# Supabase Configuration (Required for YouTube OAuth)
# ---------------------------------------------------
# Supabase API Gateway URL (Kong proxy)
VITE_SUPABASE_URL=http://localhost:8000

# Supabase Anonymous Key (for Kong API Gateway authentication)
# Get this from your Supabase .env file (ANON_KEY)
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# API Configuration
# -----------------
# Backend API URL (used during development via Vite proxy)
VITE_API_URL=http://localhost:3000

# App Configuration
# -----------------
VITE_APP_NAME=TubeArchive
VITE_APP_VERSION=1.0.0
