{
  "name": "insighta",
  "version": "0.3.0",
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "prettier --write"
    ]
  },
  "description": "Insighta - Personal knowledge management platform powered by YouTube playlists",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "yt-sync": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "ts-node src/index.ts",
    "dev:all": "concurrently --names \"API,FRONTEND\" --prefix-colors \"blue,green\" \"npm run api:dev\" \"cd frontend && npm run dev\"",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "tsc",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build && npm run build:frontend",
    "install:all": "npm install && cd frontend && npm install",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "build:watch": "tsc --watch",
    "start": "node dist/index.js",
    "cli": "ts-node src/cli/index.ts",
    "api:dev": "tsx watch src/api/server.ts",
    "api:start": "node dist/api/server.js",
    "api:build": "tsc && npm run generate:openapi",
    "generate:openapi": "tsx scripts/generate-openapi.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "jest --testPathPattern=tests/e2e",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:push": "prisma db push",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install",
    "precommit": "npm run lint && npm run typecheck",
    "prepush": "npm run test",
    "create:adapter": "tsx scripts/create-adapter.ts"
  },
  "keywords": [
    "youtube",
    "playlist",
    "sync",
    "knowledge-management",
    "learning",
    "video",
    "metadata",
    "cli",
    "api",
    "rest-api",
    "fastify",
    "openapi",
    "documentation"
  ],
  "author": "JK42JJ",
  "homepage": "https://insighta.one",
  "repository": {
    "type": "git",
    "url": "https://github.com/JK42JJ/insighta.git"
  },
  "bugs": {
    "url": "https://github.com/JK42JJ/insighta/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^8.4.2",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^7.2.3",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^9.0.1",
    "@fastify/swagger": "^8.13.0",
    "@fastify/swagger-ui": "^2.0.1",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.7.1",
    "@scalar/fastify-api-reference": "^1.24.23",
    "bcrypt": "^6.0.0",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "fastify": "^4.25.2",
    "googleapis": "^128.0.0",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3",
    "tslib": "^2.8.1",
    "winston": "^3.11.0",
    "youtube-caption-extractor": "^1.9.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "concurrently": "^9.1.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^16.3.2",
    "msw": "^2.7.3",
    "prettier": "^3.1.1",
    "prisma": "^5.7.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=9.0.0"
  }
}
