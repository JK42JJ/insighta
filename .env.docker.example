# =============================================================================
# Docker Environment Configuration
# =============================================================================
# Copy this file to .env.docker and fill in your values:
#   cp .env.docker.example .env.docker
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
# External PostgreSQL connection string
# Examples:
#   Neon:     postgresql://user:pass@ep-xxx.aws.neon.tech/neondb?sslmode=require
#   Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
#   Railway:  postgresql://postgres:pass@xxx.railway.app:5432/railway
DATABASE_URL=postgresql://username:password@hostname:5432/database?sslmode=require

# -----------------------------------------------------------------------------
# YouTube API (Required)
# -----------------------------------------------------------------------------
# OAuth 2.0 credentials from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=your_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_client_secret

# Redirect URI for OAuth (update with your deployed URL)
YOUTUBE_REDIRECT_URI=http://localhost:3000/oauth2callback

# OAuth tokens (obtained after OAuth flow completion)
YOUTUBE_ACCESS_TOKEN=
YOUTUBE_REFRESH_TOKEN=

# Alternative: API Key (read-only, limited features)
YOUTUBE_API_KEY=

# -----------------------------------------------------------------------------
# AI Services (Optional - for video summarization)
# -----------------------------------------------------------------------------
# Google Gemini API: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# Security (Required)
# -----------------------------------------------------------------------------
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=your_64_character_hex_string_here

# JWT secret for API authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
API_PORT=3000

# CORS (comma-separated list of allowed origins)
CORS_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# -----------------------------------------------------------------------------
# Sync Configuration
# -----------------------------------------------------------------------------
DEFAULT_SYNC_INTERVAL=3600000
MAX_CONCURRENT_SYNCS=5
RETRY_ATTEMPTS=3

# -----------------------------------------------------------------------------
# YouTube API Quota
# -----------------------------------------------------------------------------
DAILY_QUOTA_LIMIT=10000
QUOTA_WARNING_THRESHOLD=9000
